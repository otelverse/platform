{
  "source": ["design-tokens/tokens/**/*.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "dist/",
      "files": [
        {
          "destination": "tokens.css",
          "format": "css/variables",
          "options": {
            "outputReferences": true,
            "selector": ":root",
            "prefix": "otv"
          }
        }
      ]
    },
    "json": {
      "buildPath": "dist/",
      "files": [
        {
          "destination": "tokens.json",
          "format": "json/nested"
        }
      ]
    }
  }
}
