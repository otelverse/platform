load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "storage",
    srcs = ["storage.go"],
    importpath = "github.com/otelverse/session-replay-service/internal/storage",
    visibility = ["//packages/session-replay/service:__subpackages__"],
    deps = ["@com_github_lib_pq//:pq"],
)

alias(
    name = "go_default_library",
    actual = ":storage",
    visibility = ["//packages/session-replay/service:__subpackages__"],
)

go_test(
    name = "storage_test",
    srcs = ["storage_test.go"],
    embed = [":storage"],
    deps = [
        "@com_github_stretchr_testify//require:go_default_library",  # keep
        "@com_github_testcontainers_testcontainers_go//:testcontainers-go",
        "@com_github_testcontainers_testcontainers_go//wait",
    ],
)
