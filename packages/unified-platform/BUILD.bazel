load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library")

package(default_visibility = ["//visibility:public"])

go_library(
    name = "platform_lib",
    srcs = glob(["*.go"]),
    importpath = "github.com/otelverse/unified-platform",
    visibility = ["//visibility:public"],
)

go_binary(
    name = "platform",
    embed = [":platform_lib"],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "all",
    srcs = glob(["**"]),
)
