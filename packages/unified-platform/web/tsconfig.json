{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@otelverse/ui-kit": ["../../../libs/ui-kit/src"],
      "@otelverse/api-hooks": ["../../../libs/api-hooks/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
