{
  "name": "@otelverse/web",
  "version": "0.5.0-dev",
  "description": "Auto-instrumentation browser library for OTelVerse platform",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/otelverse-web.iife.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "node scripts/build.mjs",
    "test": "jest --passWithNoTests --config jest.config.js",
    "lint": "biome check --apply src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.41.0",
    "@opentelemetry/instrumentation-document-load": "^0.63.0",
    "@opentelemetry/instrumentation-fetch": "^0.218.0",
    "@opentelemetry/instrumentation-xml-http-request": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-trace-web": "^2.7.0",
    "web-vitals": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.2.4",
    "typescript": "^5.5.4"
  }
}
