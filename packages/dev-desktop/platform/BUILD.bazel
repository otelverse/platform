load("@io_bazel_rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "platform_lib",
    srcs = [
        "attrs.go",
        "graphql.go",
        "main.go",
        "migration.go",
        "otlp_receiver.go",
    ],
    embedsrcs = ["migrations/001_init.sql"],
    importpath = "github.com/otelverse/unified-platform/packages/dev-desktop/platform",
    visibility = ["//visibility:private"],
    deps = [
        "@com_github_marcboeker_go_duckdb//:go_default_library",
        "@io_opentelemetry_go_proto_otlp//collector/logs/v1:logs",
        "@io_opentelemetry_go_proto_otlp//collector/trace/v1:trace",
        "@io_opentelemetry_go_proto_otlp//common/v1:common",
        "@io_opentelemetry_go_proto_otlp//logs/v1:logs",
        "@io_opentelemetry_go_proto_otlp//trace/v1:trace",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_grpc//credentials/insecure",
    ],
)

go_binary(
    name = "platform",
    embed = [":platform_lib"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "platform_test",
    srcs = ["main_test.go"],
    embed = [":platform_lib"],
)
